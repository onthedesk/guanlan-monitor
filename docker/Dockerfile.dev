# Development image for WorldMonitor.
# Source code is volume-mounted at runtime for HMR.
# node_modules are installed at build time and preserved via anonymous volume.

FROM node:22-alpine

RUN apk add --no-cache git

WORKDIR /app

# Copy dependency manifests first for layer caching.
COPY package.json package-lock.json ./
COPY blog-site/package.json blog-site/package-lock.json ./blog-site/

# Override at build time if npmjs.org is flaky from your network, e.g.:
# docker compose build --build-arg NPM_CONFIG_REGISTRY=https://registry.npmmirror.com
ARG NPM_CONFIG_REGISTRY=https://registry.npmjs.org
RUN npm ci --registry="${NPM_CONFIG_REGISTRY}"

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
