# Development image for WorldMonitor.
# Source code is volume-mounted at runtime for HMR.
# node_modules are installed at build time and preserved via anonymous volume.

FROM node:22-alpine

RUN apk add --no-cache git

WORKDIR /app

# Copy dependency manifests first for layer caching.
COPY package.json package-lock.json ./
COPY blog-site/package.json blog-site/package-lock.json ./blog-site/

RUN npm ci

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
