# ============================================
# WorldMonitor — Dev/Demo Docker Environment
# ============================================
# cp .env.dev.example .env.dev  &&  edit .env.dev
#
# Redis vars (UPSTASH_*) are injected by docker-compose;
# do NOT set them here.
# ============================================


# ------ Docker / Networking ------

# Host port for vite dev server (1Panel reverse-proxy points here)
WM_DEV_PORT=3000

# Redis connection for redis-rest-proxy container.
# Point to your 1Panel Redis. Use container name or host IP.
# DB 0 for dev, DB 1 for prod (isolation).
REDIS_URL=redis://host.docker.internal:6379/0

# Shared token between app and redis-rest-proxy (any random string)
REDIS_REST_TOKEN=dev-token-change-me

# HMR through reverse proxy: set to your dev subdomain.
# Leave empty if accessing directly via IP:port.
HMR_HOST=
# HMR_CLIENT_PORT=443


# ------ Site Configuration ------

VITE_VARIANT=full
# Leave empty — same-domain API (vite sebufApiPlugin handles /api/* in dev)
VITE_WS_API_URL=


# ------ AI Summarization ------

GROQ_API_KEY=
OPENROUTER_API_KEY=


# ------ Market Data ------

FINNHUB_API_KEY=


# ------ Energy Data ------

EIA_API_KEY=


# ------ Economic Data ------

FRED_API_KEY=


# ------ Air Quality ------

OPENAQ_API_KEY=
WAQI_API_KEY=


# ------ Aviation ------

AVIATIONSTACK_API=
ICAO_API_KEY=


# ------ Aircraft Tracking ------

WINGBITS_API_KEY=


# ------ Conflict & Protest ------

ACLED_EMAIL=
ACLED_PASSWORD=
UCDP_ACCESS_TOKEN=


# ------ Internet Outages ------

CLOUDFLARE_API_TOKEN=


# ------ Satellite Fire Detection ------

NASA_FIRMS_API_KEY=


# ------ Climate Disasters ------

RELIEFWEB_APPNAME=


# ------ Self-Hosted LLM (optional) ------

LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
