# ============================================
# WorldMonitor — Dev/Demo Docker Environment
# ============================================
# cp .env.dev.example .env.dev  &&  edit .env.dev
#
# Redis vars (UPSTASH_*) are injected by docker-compose;
# do NOT set them here.
# ============================================


# ------ Docker / Networking ------

# npm registry for `docker compose build` (if npmjs.org fails inside Docker, try mirror)
# NPM_CONFIG_REGISTRY=https://registry.npmmirror.com

# Host port for vite dev server (published for debugging; OpenResty on 1panel-network can use guanlan-dev-app:3000 instead)
WM_DEV_PORT=3000

# Redis connection for redis-rest-proxy (TCP). Compose attaches the proxy to 1panel-network.
# Prefer 1Panel Redis *container name* (DNS on that network; survives restarts / IP changes), e.g.:
# REDIS_URL=redis://1Panel-redis-xxxx:6379/0
# Fallback: Redis published on host → host.docker.internal
REDIS_URL=redis://host.docker.internal:6379/0

# Shared token between app and redis-rest-proxy (any random string)
REDIS_REST_TOKEN=dev-token-change-me

# HMR through reverse proxy: set to your dev subdomain.
# Leave empty if accessing directly via IP:port.
HMR_HOST=
# HMR_CLIENT_PORT=443


# ------ Site Configuration ------

VITE_VARIANT=full
# Leave empty — same-domain API (vite sebufApiPlugin handles /api/* in dev)
VITE_WS_API_URL=


# ------ AI Summarization ------

GROQ_API_KEY=
OPENROUTER_API_KEY=


# ------ Market Data ------

FINNHUB_API_KEY=


# ------ Energy Data ------

EIA_API_KEY=


# ------ Economic Data ------

FRED_API_KEY=


# ------ Air Quality ------

OPENAQ_API_KEY=
WAQI_API_KEY=


# ------ Aviation ------

AVIATIONSTACK_API=
ICAO_API_KEY=


# ------ Aircraft Tracking ------

WINGBITS_API_KEY=


# ------ Conflict & Protest ------

ACLED_EMAIL=
ACLED_PASSWORD=
UCDP_ACCESS_TOKEN=


# ------ Internet Outages ------

CLOUDFLARE_API_TOKEN=


# ------ Satellite Fire Detection ------

NASA_FIRMS_API_KEY=


# ------ Climate Disasters ------

RELIEFWEB_APPNAME=


# ------ Self-Hosted LLM (optional) ------

LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
