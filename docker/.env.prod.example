# ============================================
# WorldMonitor — Production Docker Environment
# ============================================
# cp .env.prod.example .env.prod  &&  edit .env.prod
#
# Redis vars (UPSTASH_*) are injected by docker-compose;
# do NOT set them here.
# ============================================


# ------ Docker / Networking ------

# Host port for nginx (1Panel reverse-proxy points here)
WM_PROD_PORT=8080

# Build-time variant (also set as build arg in docker-compose)
VITE_VARIANT=full

# Redis connection for redis-rest-proxy container.
# Point to your 1Panel Redis. Use container name or host IP.
# DB 1 for prod (DB 0 is dev).
REDIS_URL=redis://host.docker.internal:6379/1

# Shared token between app and redis-rest-proxy (use a strong random string)
# Generate: openssl rand -hex 24
REDIS_REST_TOKEN=

# local-api-server port inside the container (default 46123, rarely needs change)
# LOCAL_API_PORT=46123


# ------ Site Configuration ------

# Leave empty — same-domain API (nginx proxies /api/* to local-api-server)
VITE_WS_API_URL=


# ------ AI Summarization ------

GROQ_API_KEY=
OPENROUTER_API_KEY=


# ------ Market Data ------

FINNHUB_API_KEY=


# ------ Energy Data ------

EIA_API_KEY=


# ------ Economic Data ------

FRED_API_KEY=


# ------ Air Quality ------

OPENAQ_API_KEY=
WAQI_API_KEY=


# ------ Aviation ------

AVIATIONSTACK_API=
ICAO_API_KEY=


# ------ Aircraft Tracking ------

WINGBITS_API_KEY=


# ------ Conflict & Protest ------

ACLED_EMAIL=
ACLED_PASSWORD=
UCDP_ACCESS_TOKEN=


# ------ Internet Outages ------

CLOUDFLARE_API_TOKEN=


# ------ Satellite Fire Detection ------

NASA_FIRMS_API_KEY=


# ------ Climate Disasters ------

RELIEFWEB_APPNAME=


# ------ Self-Hosted LLM (optional) ------

LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=


# ------ Desktop Cloud Fallback Keys (optional) ------

WORLDMONITOR_VALID_KEYS=
